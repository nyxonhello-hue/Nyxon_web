{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/pro", "destination": "https://nyxon-server-production.up.railway.app/pro" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
